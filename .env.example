NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
# URL of your Supabase project
NEXT_PUBLIC_SUPABASE_URL=
# Publishable (anon) key — safe for the browser; used for cookie-based session management
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret (service-role) key — MUST only be used in backend API routes; NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# LLM Integration (OpenAI-compatible)
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
# Local development only. Keep false in production.
NEXT_PUBLIC_ALLOW_MOCK=false

# Creem.io
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=

# Creem Product IDs (create these in your Creem dashboard)
CREEM_STARTER_PRODUCT_ID=
CREEM_CREATOR_PRODUCT_ID=
CREEM_PRO_PRODUCT_ID=
CREEM_TEAM_PRODUCT_ID=

# WeChat Pay (coming soon)
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_API_KEY=
# WECHAT_PAY_CERT_SERIAL=
# WECHAT_PAY_PRIVATE_KEY=

# Alipay (coming soon)
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=
# ALIPAY_PUBLIC_KEY=

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
